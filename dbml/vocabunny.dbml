  //   paid_at timestamptz
  //   created_at timestamptz [not null, default: `now()`]
  // }

  // Ref: tbl_orders.user_id > tbl_users.id
  // Ref: tbl_order_items.order_id > tbl_orders.id
  // Ref: tbl_order_items.product_id > tbl_products.id
  // Ref: tbl_payments.order_id > tbl_orders.id
*/

// --------------------------------------------------
// Economy: Coins / Wallet / Ledger
// --------------------------------------------------

// Actor Wallets: กระเป๋าเงินของผู้เล่น ใช้เก็บยอด coin ปัจจุบันแบบ cached เพื่ออ่านเร็ว (source of truth คือ coin_ledger)
Table tbl_actor_wallets {
  actor_id uuid [pk, not null, note: 'Foreign key อ้างอิงไปยัง actor_identity.actor_id ระบุผู้เล่นแบบ canonical']
  coin_balance bigint [not null, default: 0, note: 'ยอด coin คงเหลือปัจจุบัน (cached) สำหรับอ่านเร็วใน UI/logic']

  created_by uuid [note: 'user_id ของ admin หรือ system ที่สร้างหรือปรับ wallet (optional)']
  updated_by uuid [note: 'user_id ของ admin หรือ system ที่แก้ไข wallet ล่าสุด (optional)']
  created_at timestamptz [not null, default: `now()`, note: 'เวลาที่สร้าง wallet (server time)']
  updated_at timestamptz [not null, default: `now()`, note: 'เวลาที่อัปเดตยอด coin ล่าสุด']
  deleted_at timestamptz [note: 'เวลาที่ลบ wallet แบบ soft delete หากเป็น NULL หมายถึงยังใช้งานอยู่']

  Indexes {
    (deleted_at)
  }
}
Ref: tbl_actor_wallets.actor_id > tbl_actor_identity.actor_id

// Coin Ledger: บันทึกธุรกรรม coin แบบ immutable (source of truth) ใช้สำหรับ audit, rollback และ debug
Table tbl_coin_ledger {
  id uuid [pk, note: 'Primary key ของ coin transaction ใช้ UUID เพื่ออ้างอิงธุรกรรมแต่ละครั้ง']
  actor_id uuid [not null, note: 'Foreign key อ้างอิงไปยัง actor_identity.actor_id ระบุผู้เล่นแบบ canonical']
  source_type coin_source_type [not null, note: 'แหล่งที่มาของการเปลี่ยนแปลง coin']
  source_ref_id uuid [note: 'อ้างอิง entity ต้นทางของ transaction เช่น quest_claim_id, trophy_id, order_id (optional)']
  coin_delta int [not null, note: 'จำนวน coin ที่เปลี่ยนแปลง (+ ได้รับ, - ใช้จ่าย)']
  balance_after bigint [note: 'ยอด coin หลังทำ transaction นี้ (ใช้สำหรับ debug/audit เท่านั้น)']

  created_by uuid [note: 'user_id ของ admin หรือ system ที่สร้าง transaction (optional)']
  updated_by uuid [note: 'user_id ของ admin (ไม่ควรใช้ เพราะ ledger เป็น immutable)']
  created_at timestamptz [not null, default: `now()`, note: 'เวลาที่เกิดธุรกรรม coin (server time)']
  updated_at timestamptz [not null, default: `now()`, note: 'ไม่ควรถูกแก้ไข (ledger immutable)']
  deleted_at timestamptz [note: 'ไม่ควรใช้ (ledger immutable), เก็บไว้เพื่อ consistency เท่านั้น']

  Indexes {
    (actor_id, created_at)
    (source_type, created_at)
    (deleted_at)
  }
}
Ref: tbl_coin_ledger.actor_id > tbl_actor_identity.actor_id
// Coin Source Type Enum: แหล่งที่มาของการเปลี่ยนแปลง coin
Enum coin_source_type {
  DAILY_QUEST
  MONTHLY_TROPHY
  STREAK_MILESTONE
  LEVEL_UP
  SHOP_PURCHASE
  GACHA
  ADMIN_ADJUST
  EVENT
  REFUND
  PROMOTION
  SYSTEM_ADJUST
}

// Coin Transactions: ใช้เป็น idempotency key เพื่อป้องกันการได้/เสีย coin ซ้ำจาก action เดิม
Table tbl_coin_transactions {
  id uuid [pk, note: 'Primary key ของ coin transaction idempotency record']
  actor_id uuid [not null, note: 'Foreign key อ้างอิงไปยัง actor_identity.actor_id ระบุผู้เล่น']
  idempotency_key text [not null, note: 'คีย์กันซ้ำ เช่น dailyquest:2026-01-15:questId']
  source_type coin_source_type [note: 'ประเภทแหล่งที่มาของ coin (optional ใช้ debug/trace)']

  created_by uuid [note: 'user_id ของ admin หรือ system ที่สร้าง record (optional)']
  created_at timestamptz [not null, default: `now()`, note: 'เวลาที่บันทึก idempotency key (server time)']

  Indexes {
    (actor_id, idempotency_key) [unique]
  }
}
Ref: tbl_coin_transactions.actor_id > tbl_actor_identity.actor_id

// --------------------------------------------------
// Items / Inventory / Gacha / Shop
// --------------------------------------------------

// NOTES / DESIGN:
// - Use a coin ledger (audit-friendly) instead of only a "coins" column.
// - Inventory supports both stackable consumables and time-limited effects.
// - Time-limited effects should be represented as "active buffs" with expires_at.
// - Prices are stored in item catalog; purchases write to ledger + inventory.
// - actor_identity is assumed to exist (supports guest + user).Enum
// Example meta payloads (informational):
// STREAK_FREEZE: { "duration_hours": 24, "auto_consume": true }
// EXP_BOOST_1H : { "exp_multiplier": 1.5, "duration_minutes": 60, "stacking": "no" }
// HINT_TOKEN   : { "hint_reduce_choices_to": 2 }
// DOUBLE_COINS : { "coin_multiplier": 2.0, "duration_hours": 24, "stacking": "no" }

// Items: ไอเท็มในระบบเศรษฐกิจภายในเกม ใช้สำหรับ shop, reward, inventory และ effect ต่าง ๆ
Table tbl_items {
  id uuid [pk, note: 'Primary key ของ item ใช้ UUID เพื่อรองรับการอ้างอิงและการขยายระบบ']
  key text [not null, unique, note: 'รหัสไอเท็มแบบ unique ใช้เป็น identifier เช่น STREAK_FREEZE, EXP_BOOST_50']
  name text [not null, note: 'ชื่อไอเท็มที่แสดงให้ผู้ใช้เห็น']
  rarity int [not null, note: 'ระดับความหายากของไอเท็ม (เช่น 1=common, 2=uncommon, 3=rare, 4=epic, 5=legendary)']
  meta jsonb [note: 'ข้อมูลเพิ่มเติมของไอเท็มแบบยืดหยุ่น เช่น effect, duration, stack_policy']

  created_by uuid [note: 'user_id ของ admin ที่สร้างหรือแก้ไข item (optional)']
  updated_by uuid [note: 'user_id ของ admin ที่แก้ไข item ล่าสุด (optional)']
  created_at timestamptz [not null, default: `now()`, note: 'เวลาที่สร้าง item (server time)']
  updated_at timestamptz [not null, default: `now()`, note: 'เวลาที่แก้ไขข้อมูล item ล่าสุด']
  deleted_at timestamptz [note: 'เวลาที่ลบ item แบบ soft delete หากเป็น NULL หมายถึงยังใช้งานอยู่']

  Indexes {
    (key)
    (rarity)
    (deleted_at)
  }
}
Ref: tbl_items.created_by > tbl_users.id
Ref: tbl_items.updated_by > tbl_users.id

// Item Catalog: รายการสินค้าในร้าน ใช้กำหนดราคา coin, ประเภทไอเท็ม และ effect ที่จะได้รับ
Table tbl_item_catalog {
  id uuid [pk, note: 'Primary key ของ item catalog ใช้ UUID เพื่ออ้างอิงสินค้าในร้าน']
  sku text [not null, unique, note: 'รหัสสินค้าแบบ business key เช่น STREAK_FREEZE, EXP_BOOST_1H']
  name text [not null, note: 'ชื่อไอเท็มที่แสดงในร้าน']
  description text [note: 'คำอธิบายไอเท็ม (optional)']
  item_type item_type [not null, note: 'ประเภทไอเท็ม เช่น CONSUMABLE, TIMED_BUFF']
  price_coins int [not null, note: 'ราคาสินค้าเป็น coin เช่น 50, 100, 150']
  is_active boolean [not null, default: true, note: 'ระบุว่าสินค้านี้ยังเปิดขายอยู่หรือไม่']
  meta jsonb [note: 'ข้อมูล effect ของไอเท็ม เช่น duration, percent, stack_policy']

  created_by uuid [note: 'user_id ของ admin ที่สร้างหรือแก้ไขสินค้า (optional)']
  updated_by uuid [note: 'user_id ของ admin ที่แก้ไขสินค้าในร้านล่าสุด']
  created_at timestamptz [not null, default: `now()`, note: 'เวลาที่สร้าง item catalog (server time)']
  updated_at timestamptz [not null, default: `now()`, note: 'เวลาที่แก้ไข item catalog ล่าสุด']
  deleted_at timestamptz [note: 'เวลาที่ลบสินค้าแบบ soft delete หากเป็น NULL หมายถึงยังใช้งานอยู่']

  Indexes {
    (sku)
    (is_active)
    (item_type)
    (deleted_at)
  }
}
// Item Type Enum: ประเภทของไอเท็มในร้าน
Enum item_type {
  CONSUMABLE   // ใช้แล้วหมดไป เช่น Hint Token
  TIMED_BUFF   // มีระยะเวลา เช่น EXP Boost, Double Coins
}

// Actor Inventory: คลังไอเท็มของผู้เล่น ใช้เก็บจำนวนไอเท็มที่ผู้เล่นมีอยู่ในปัจจุบัน
Table tbl_actor_inventory {
  actor_id uuid [not null, note: 'Foreign key อ้างอิงไปยัง actor_identity.actor_id ระบุผู้เล่นแบบ canonical']
  item_id uuid [not null, note: 'Foreign key อ้างอิงไปยัง items.id ระบุไอเท็มที่ผู้เล่นถือครอง']
  qty int [not null, default: 0, note: 'จำนวนไอเท็มที่ผู้เล่นมีอยู่ (ต้องไม่ติดลบ)']

  created_by uuid [note: 'user_id ของ admin หรือ system ที่สร้างหรือปรับ inventory (optional)']
  updated_by uuid [note: 'user_id ของ admin หรือ system ที่แก้ไข inventory ล่าสุด']
  created_at timestamptz [not null, default: `now()`, note: 'เวลาที่สร้าง record inventory (server time)']
  updated_at timestamptz [not null, default: `now()`, note: 'เวลาที่อัปเดต inventory ล่าสุด']
  deleted_at timestamptz [note: 'เวลาที่ลบ inventory แบบ soft delete หากเป็น NULL หมายถึงยังใช้งานอยู่']

  Indexes {
    (actor_id, item_id) [pk]
    (item_id)
    (deleted_at)
  }
}
Ref: tbl_actor_inventory.item_id > tbl_item_catalog.id
Ref: tbl_actor_inventory.actor_id > tbl_actor_identity.actor_id
Ref: tbl_actor_inventory.item_id > tbl_items.id

// Gacha Rolls: บันทึกการสุ่มไอเท็ม (ฟรีรายวันหรือใช้ coins) ใช้เป็นประวัติและ audit
Table tbl_gacha_rolls {
  id uuid [pk, note: 'Primary key ของ gacha roll ใช้ UUID เพื่ออ้างอิงการสุ่มแต่ละครั้ง']
  actor_id uuid [not null, note: 'Foreign key อ้างอิงไปยัง actor_identity.actor_id ระบุผู้เล่นที่ทำการสุ่ม']
  roll_type gacha_roll_type [not null, note: 'ประเภทการสุ่ม เช่น FREE_DAILY หรือ PAID']
  cost_coins int [not null, default: 0, note: 'จำนวน coins ที่ใช้ในการสุ่ม (0 = ฟรี)']
  result_items jsonb [not null, note: 'ผลลัพธ์การสุ่มไอเท็มแบบ snapshot เช่น item_id, qty, rarity']
  /*
    [
      {
        "item_id": "uuid-1",
        "key": "STREAK_FREEZE",
        "qty": 1,
        "rarity": 3
      }
    ]
  */
  rolled_at timestamptz [not null, default: `now()`, note: 'เวลาที่ทำการสุ่ม (server time)']

  created_by uuid [note: 'user_id ของ admin หรือ system ที่สร้าง record gacha roll (optional)']
  updated_by uuid [note: 'user_id ของ admin หรือ system ที่แก้ไข record gacha roll ล่าสุด']
  created_at timestamptz [not null, default: `now()`, note: 'เวลาที่สร้าง record gacha roll']
  updated_at timestamptz [not null, default: `now()`, note: 'เวลาที่แก้ไข record gacha roll ล่าสุด']
  deleted_at timestamptz [note: 'เวลาที่ลบ gacha roll แบบ soft delete หากเป็น NULL หมายถึงยังใช้งานอยู่']

  Indexes {
    (actor_id, rolled_at)
    (roll_type, rolled_at)
    (deleted_at)
  }
}
Ref: tbl_gacha_rolls.actor_id > tbl_actor_identity.actor_id
// Gacha Roll Type Enum: ประเภทการสุ่มไอเท็ม
Enum gacha_roll_type {
  FREE_DAILY  // สุ่มฟรีรายวัน (จำกัดวันละ 1 ครั้ง)
  PAID        // สุ่มโดยใช้ coins
}

// Shop Orders: ใบสั่งซื้อสินค้าในร้านของผู้เล่น ใช้คู่กับ shop_order_items และ coin_ledger
Table tbl_shop_orders {
  id uuid [pk, note: 'Primary key ของคำสั่งซื้อสินค้า ใช้ UUID เพื่ออ้างอิง order']
  actor_id uuid [not null, note: 'Foreign key อ้างอิงไปยัง actor_identity.actor_id ระบุผู้เล่นที่ทำการสั่งซื้อ']
  status shop_order_status [not null, default: 'COMPLETED', note: 'สถานะของคำสั่งซื้อ']
  total_coins int [not null, note: 'จำนวน coin รวมของคำสั่งซื้อ (เก็บเป็นบวก)']

  created_by uuid [note: 'user_id ของ admin หรือ system ที่สร้าง order (optional)']
  updated_by uuid [note: 'user_id ของ admin หรือ system ที่แก้ไข order ล่าสุด']
  created_at timestamptz [not null, default: `now()`, note: 'เวลาที่สร้างคำสั่งซื้อ (server time)']
  updated_at timestamptz [not null, default: `now()`, note: 'เวลาที่อัปเดตคำสั่งซื้อล่าสุด']
  deleted_at timestamptz [note: 'เวลาที่ลบ order แบบ soft delete หากเป็น NULL หมายถึงยังใช้งานอยู่']

  Indexes {
    (actor_id, created_at)
    (status)
    (deleted_at)
  }
}
Ref: tbl_shop_orders.actor_id > tbl_actor_identity.actor_id
// Shop Order Status Enum: สถานะของคำสั่งซื้อในร้าน
Enum shop_order_status {
  COMPLETED
  CANCELLED
  FAILED
}

// Shop Order Items: รายการสินค้าแต่ละชิ้นภายในคำสั่งซื้อ ใช้เป็น snapshot ราคา/จำนวน ณ เวลาซื้อ
Table tbl_shop_order_items {
  order_id uuid [not null, note: 'Foreign key อ้างอิงไปยัง shop_orders.id ระบุคำสั่งซื้อหลัก']
  item_id uuid [not null, note: 'Foreign key อ้างอิงไปยัง item_catalog.id ระบุสินค้าที่ถูกซื้อ']
  quantity int [not null, default: 1, note: 'จำนวนสินค้าที่ซื้อในรายการนี้']
  unit_price_coins int [not null, note: 'ราคา coin ต่อหน่วยของสินค้า (snapshot ณ เวลาซื้อ)']
  line_total_coins int [not null, note: 'ราคารวมของรายการนี้ = unit_price_coins × quantity']

  created_by uuid [note: 'user_id ของ admin หรือ system ที่สร้างรายการสินค้าใน order (optional)']
  updated_by uuid [note: 'user_id ของ admin หรือ system ที่แก้ไขรายการสินค้าใน order ล่าสุด']
  created_at timestamptz [not null, default: `now()`, note: 'เวลาที่สร้าง order item (server time)']
  updated_at timestamptz [not null, default: `now()`, note: 'เวลาที่แก้ไข order item ล่าสุด']
  deleted_at timestamptz [note: 'เวลาที่ลบ order item แบบ soft delete หากเป็น NULL หมายถึงยังใช้งานอยู่']

  Indexes {
    (order_id, item_id) [pk]
    (item_id)
    (deleted_at)
  }
}
Ref: tbl_shop_order_items.order_id > tbl_shop_orders.id
Ref: tbl_shop_order_items.item_id > tbl_item_catalog.id

// Shop Purchase Requests: ใช้เป็น idempotency สำหรับการสั่งซื้อ ป้องกันการตัด coin ซ้ำจากการ submit ซ้ำของ client
Table tbl_shop_purchase_requests {
  id uuid [pk, note: 'Primary key ของ purchase request ใช้ UUID เพื่ออ้างอิงคำขอสั่งซื้อ']
  actor_id uuid [not null, note: 'Foreign key อ้างอิงไปยัง actor_identity.actor_id ระบุผู้เล่นที่ทำการสั่งซื้อ']
  client_request_id uuid [not null, note: 'idempotency key จากฝั่ง client เพื่อกันการ submit ซ้ำ']
  order_id uuid [note: 'Foreign key อ้างอิงไปยัง shop_orders.id ระบุ order ที่ถูกสร้าง (nullable จนกว่าจะสร้างสำเร็จ)']

  created_by uuid [note: 'user_id ของ admin หรือ system ที่สร้างรายการสินค้าใน order (optional)']
  updated_by uuid [note: 'user_id ของ admin หรือ system ที่แก้ไขรายการสินค้าใน order ล่าสุด']
  created_at timestamptz [not null, default: `now()`, note: 'เวลาที่สร้าง order item (server time)']
  updated_at timestamptz [not null, default: `now()`, note: 'เวลาที่แก้ไข order item ล่าสุด']
  deleted_at timestamptz [note: 'เวลาที่ลบ order item แบบ soft delete หากเป็น NULL หมายถึงยังใช้งานอยู่']

  Indexes {
    (actor_id, client_request_id) [unique]
  }
}
Ref: tbl_shop_purchase_requests.actor_id > tbl_actor_identity.actor_id
Ref: tbl_shop_purchase_requests.order_id > tbl_shop_orders.id

// Stackable items (e.g., Freeze, Hint Token)
// Timed buffs typically should NOT be stored here as "quantity with expires_at" (ambiguous),
// better store active effects in actor_buffs.
// However, you can still keep unused buff items here as quantity.

// Item Consumptions: บันทึกการใช้ไอเท็มของผู้เล่นแบบ audit/event log ใช้ตรวจสอบการใช้งานและ debug
Table tbl_item_consumptions {
  id uuid [pk, note: 'Primary key ของการใช้ไอเท็ม ใช้ UUID เพื่ออ้างอิงเหตุการณ์การใช้งาน']
  actor_id uuid [not null, note: 'Foreign key อ้างอิงไปยัง actor_identity.actor_id ระบุผู้เล่นที่ใช้ไอเท็ม']
  item_id uuid [not null, note: 'Foreign key อ้างอิงไปยัง items.id ระบุไอเท็มที่ถูกใช้']
  quantity int [not null, default: 1, note: 'จำนวนไอเท็มที่ถูกใช้ในเหตุการณ์นี้']
  reason item_consumption_reason [note: 'สาเหตุการใช้ไอเท็ม เช่น STREAK_AUTO_FREEZE, USER_ACTION_HINT']
  ref_attempt_id uuid [note: 'อ้างอิง attempt ที่เกี่ยวข้อง เช่น question_set_attempts.id (optional)']

  created_by uuid [note: 'user_id ของ admin หรือ system ที่บันทึกการใช้ไอเท็ม (optional)']
  updated_by uuid [note: 'user_id ของ admin หรือ system ที่แก้ไข record ล่าสุด']
  created_at timestamptz [not null, default: `now()`, note: 'เวลาที่บันทึกการใช้ไอเท็ม (server time)']
  updated_at timestamptz [not null, default: `now()`, note: 'เวลาที่แก้ไข record ล่าสุด']
  deleted_at timestamptz [note: 'เวลาที่ลบ record แบบ soft delete หากเป็น NULL หมายถึงยังใช้งานอยู่']

  Indexes {
    (actor_id, created_at)
    (item_id, created_at)
    (deleted_at)
  }
}
Ref: tbl_item_consumptions.item_id > tbl_items.id
Ref: tbl_item_consumptions.actor_id > tbl_actor_identity.actor_id
Ref: tbl_item_consumptions.item_id > tbl_item_catalog.id
Ref: tbl_item_consumptions.ref_attempt_id > tbl_question_set_attempts.id
// Item Consumption Reason Enum: สาเหตุการใช้ไอเท็ม
Enum item_consumption_reason {
  STREAK_AUTO_FREEZE // ใช้ไอเท็มวันลาอัตโนมัติเมื่อ streak ใกล้หมด
  USER_ACTION_HINT  // ผู้ใช้กดใช้ Hint ด้วยตนเอง
  QUEST_REWARD_USE  // ใช้ไอเท็มที่ได้จากรางวัล quest
  SYSTEM_EFFECT     // ใช้งานโดยระบบ (buff/automation)
}

// --------------------------------------------------
// Buffs / Effects
// --------------------------------------------------

// Actor Buffs: บัฟของผู้เล่นที่มีระยะเวลาตามเวลาจริง (real-time) เช่น EXP Boost 1 ชั่วโมง, Double Coins 24 ชั่วโมง
Table tbl_actor_buffs {
  id uuid [pk, note: 'Primary key ของ buff ใช้ UUID เพื่ออ้างอิงบัฟแต่ละครั้ง']
  actor_id uuid [not null, note: 'Foreign key อ้างอิงไปยัง actor_identity.actor_id ระบุผู้เล่นแบบ canonical']
  buff_type buff_type [not null, note: 'ประเภทของบัฟ เช่น EXP_BOOST, DOUBLE_COINS']
  source_item_id uuid [note: 'Foreign key อ้างอิงไปยัง item_catalog.id ระบุไอเท็มต้นทางของบัฟ (optional)']
  multiplier numeric [not null, default: 1.0, note: 'ตัวคูณของบัฟ เช่น 1.5 สำหรับ EXP, 2.0 สำหรับ coins']
  started_at timestamptz [not null, default: `now()`, note: 'เวลาที่บัฟเริ่มทำงาน (server time)']
  expires_at timestamptz [not null, note: 'เวลาที่บัฟหมดอายุ (server time)']
  is_active boolean [not null, default: true, note: 'สถานะบัฟปัจจุบัน (true = ยังใช้งานอยู่)']
  meta jsonb [note: 'ข้อมูลเพิ่มเติมของบัฟ เช่น stack_policy, source_context (optional)']

  created_by uuid [note: 'user_id ของ admin หรือ system ที่สร้างบัฟ (optional)']
  updated_by uuid [note: 'user_id ของ admin หรือ system ที่แก้ไขบัฟล่าสุด']
  created_at timestamptz [not null, default: `now()`, note: 'เวลาที่สร้าง record buff (server time)']
  updated_at timestamptz [not null, default: `now()`, note: 'เวลาที่แก้ไข record buff ล่าสุด']
  deleted_at timestamptz [note: 'เวลาที่ลบ buff แบบ soft delete หากเป็น NULL หมายถึงยังใช้งานอยู่']

  Indexes {
    (actor_id, is_active)
    (actor_id, expires_at)
    (buff_type, is_active)
    (deleted_at)
  }
}
Ref: tbl_actor_buffs.actor_id > tbl_actor_identity.actor_id
Ref: tbl_actor_buffs.source_item_id > tbl_item_catalog.id
// Buff Type Enum: ประเภทของบัฟที่มีผลตามเวลาจริง
Enum buff_type {
  EXP_BOOST     // เพิ่ม EXP ที่ได้รับจากกิจกรรมต่าง ๆ
  DOUBLE_COINS  // เพิ่ม coins ที่ได้รับจาก quest/reward

  STREAK_PROTECT   // ป้องกัน streak reset ชั่วคราว (แทน/เสริม freeze item)
  QUIZ_SPEED       // ลดเวลา/เพิ่มเวลาโบนัสต่อข้อ (UX/gameplay)
  ACCURACY_BOOST   // เพิ่มคะแนน/accuracy floor (event-based)
}

// Prevent stacking rules (optional helper):
// E.g., only 1 active exp_boost per actor, only 1 active double_coins per actor.
// Enforce via SQL partial unique index in migrations (DBML cannot fully express partial unique).
Table tbl_buff_activation_requests {
  id uuid [pk]
  actor_id uuid [not null]
  buff_type text [not null]
  client_request_id uuid [not null]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (actor_id, buff_type, client_request_id) [unique]
  }
}
Ref: tbl_buff_activation_requests.actor_id > tbl_actor_identity.actor_id

// --------------------------------------------------
// Analytics / Events / Telemetry
// --------------------------------------------------

// Analytics Events: บันทึกเหตุการณ์เชิงพฤติกรรม/การใช้งาน (analytics/observability) เพื่อทำ funnel, retention, debug UX ไม่ใช่ source of truth ของ logic หลัก
Table tbl_analytics_events {
  id uuid [pk, note: 'Primary key ของ analytics event ใช้ UUID เพื่ออ้างอิงเหตุการณ์แต่ละครั้ง']
  actor_id uuid [note: 'Foreign key อ้างอิงไปยัง actor_identity.actor_id ระบุผู้เล่นที่เกี่ยวข้องกับเหตุการณ์ (optional)']
  event_name text [not null, note: 'ชื่อเหตุการณ์ เช่น quiz_started, quiz_finished, item_used, gacha_rolled']
  properties jsonb [note: 'ข้อมูลเพิ่มเติมของเหตุการณ์ เช่น question_set_id, device, latency_ms, ui_version (optional)']
  occurred_at timestamptz [not null, default: `now()`, note: 'เวลาที่เกิดเหตุการณ์ (server time)']

  created_by uuid [note: 'user_id ของ admin หรือ system ที่สร้าง event (optional)']
  updated_by uuid [note: 'user_id ของ admin หรือ system ที่แก้ไข event ล่าสุด (optional)']
  created_at timestamptz [not null, default: `now()`, note: 'เวลาที่บันทึก event ลงฐานข้อมูล (server time)']
  updated_at timestamptz [not null, default: `now()`, note: 'เวลาที่แก้ไข record event ล่าสุด']
  deleted_at timestamptz [note: 'เวลาที่ลบ event แบบ soft delete หากเป็น NULL หมายถึงยังใช้งานอยู่']

  Indexes {
    (event_name, occurred_at)
    (actor_id, occurred_at)
    (deleted_at)
  }
}
Ref: tbl_analytics_events.actor_id > tbl_actor_identity.actor_id

